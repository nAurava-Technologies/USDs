    def Scope "wheel_drive"
    {
        def PhysicsRevoluteJoint "wheel_fl_joint" (
            prepend apiSchemas = ["PhysicsDriveAPI:angular", "PhysicsJointStateAPI:angular", "PhysxJointAPI"]
        )
        {
            float drive:angular:physics:damping = 2500
            float drive:angular:physics:maxForce = inf
            float drive:angular:physics:stiffness = 0
